    "#abstraction\n",
    "from abc import ABC,abstractmethod\n",
    "class Greet(ABC):\n",
    "    def say_hello(self):\n",
    "        pass\n",
    "\n",
    "class English(Greet):\n",
    "    def say_hello(self):\n",
    "        return \"hello\"\n",
    "\n",
    "g=English() \n",
    "print(g.say_hello())       "
   ]
